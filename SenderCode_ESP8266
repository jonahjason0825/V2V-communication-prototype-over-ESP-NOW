#include <Arduino.h>
#include <ESP8266WiFi.h>
const int trigPin = 5;
const int echoPin = 4;

#define SOUND_SPEED 0.034 // cm/µs
#define CM_TO_INCH 0.393701

extern "C" {
  #include <espnow.h>
}

uint8_t receiverMac[] = {0x00, 0x70, 0x07, 0x3A, 0x5D, 0x18};

// Must match ESP32 struct exactly
typedef struct proximity_warning {
  char a[32];
} proximity_warning;

proximity_warning warning;

void OnDataSent(uint8_t *mac_addr, uint8_t status) {
  Serial.print("Send status: ");
  Serial.println(status == 0 ? "SUCCESS" : "FAIL");
}

void setup() {
  Serial.begin(9600);
  delay(2000);
  Serial.println("ESP8266 → ESP32 ESP-NOW Sender");

  WiFi.mode(WIFI_STA);
  WiFi.disconnect();

  if (esp_now_init() != 0) {
    Serial.println("ESP-NOW init FAILED");
    return;
  }

  esp_now_set_self_role(ESP_NOW_ROLE_CONTROLLER);
  esp_now_register_send_cb(OnDataSent);

  
  esp_now_add_peer(receiverMac, ESP_NOW_ROLE_SLAVE, 1, NULL, 0);

  Serial.println("Sender ready");
  pinMode (trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
}

void loop() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  //10microsecond pulse section
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  //10microsecond pulse section ends
  //read the time taken for echo
  float timeTaken=pulseIn(echoPin, HIGH);
  //convert it to cm
  float distanceCm=timeTaken*0.02222;
  if (distanceCm<=6.0){
    strcpy(warning.a, "VEHICLE CLOSE AHEAD! STOP!");
  }
  else{
    strcpy(warning.a, "All clear...no cause for alarm");
  }
  
  esp_now_send(receiverMac, (uint8_t *)&warning, sizeof(warning));
  delay(2000);
}

